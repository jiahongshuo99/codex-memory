#!/usr/bin/env sh
set -eu

SOURCE=$0
while [ -L "$SOURCE" ]; do
  DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
  LINK=$(readlink "$SOURCE")
  case "$LINK" in
    /*) SOURCE=$LINK ;;
    *) SOURCE=$DIR/$LINK ;;
  esac
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
PLUGIN_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

exec python3 "$PLUGIN_ROOT/scripts/codex_memory.py" "$@"
