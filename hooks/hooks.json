{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/user_prompt_submit_hook.py",
            "timeout": 10,
            "statusMessage": "Recording memory inbox"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/stop_hook.py",
            "timeout": 600,
            "statusMessage": "Extracting memory"
          }
        ]
      }
    ]
  }
}
